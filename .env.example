APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL (prod / local avec serveur). Sans MySQL : DB_CONNECTION=sqlite + DB_DATABASE=database/database.sqlite puis php artisan migrate
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vivat
DB_USERNAME=root
DB_PASSWORD=

# Base « ancienne » pour import 0,5 % articles (tbl_cont_pg). Par défaut exclut le néerlandais (--exclude-lang=nl).
# php artisan vivat:import-old-articles
# Pour supprimer les articles nl déjà en base : php artisan vivat:remove-dutch-articles
# DB_OLD_HOST=127.0.0.1
# DB_OLD_PORT=3306
# DB_OLD_DATABASE=vivat_old
# DB_OLD_USERNAME=root
# DB_OLD_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Pour Horizon (pipeline RSS / enrichissement / génération), utiliser redis
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Désactiver le cache des pages (home, catégories) pour voir les changements DB instantanément
# VIVAT_DISABLE_PAGE_CACHE=true

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# OpenAI (enrichissement + génération d'articles)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000

# Sélection d'articles : default | actu_focus | seo_focus | long_form_focus (config/selection.php)
SELECTION_WEIGHT_PROFILE=default

VITE_APP_NAME="${APP_NAME}"
